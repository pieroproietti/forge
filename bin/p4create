#!/bin/bash
# Uso: p4create [distro|all]

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
CONFIG_FILE="${SCRIPT_DIR}/p4config"
if [ ! -f "$CONFIG_FILE" ]; then 
    echo "❌ Errore: p4config non trovato in $CONFIG_FILE!"
    exit 1
fi
source "$CONFIG_FILE"

DISTRO=$1
if [ -z "$DISTRO" ]; then
    echo "Uso: $0 [distro|all]"
    exit 1
fi

create_vm() {
    local target_name=${1^^} # Converte in maiuscolo (es. DEBIAN)
    
    # Punta alla variabile compatta VTMN_
    local var_source="VTMN_${target_name}"
    local string_value=${!var_source}

    if [ -z "$string_value" ]; then 
        echo "❌ Distro '$target_name' non configurata in p4config (variabile VTMN_ mancante)!"
        return
    fi

    # Estrazione dei 5 parametri tramite la virgola
    IFS=',' read -r vmid template_id mac ip name <<< "$string_value"

    # Controllo di sicurezza sui dati estratti
    if [ -z "$vmid" ] || [ -z "$template_id" ] || [ -z "$mac" ] || [ -z "$ip" ] || [ -z "$name" ]; then
        echo "❌ Dati incompleti per '$target_name'. Formato richiesto: VMID,TEMPLATEID,MAC,IP,NAME"
        return
    fi

    echo "🏗️  Clonazione $name (VMID: $vmid) dal template $template_id..."

    # 1. Clona il template (Full clone su ZFS)
    ssh "$PVE_TARGET" "qm clone $template_id $vmid --name $name --full"

    # 2. Configura l'hardware (Ponte su vmbr0 e fissa il MAC address)
    ssh "$PVE_TARGET" "qm set $vmid \
      --memory 2048 \
      --sockets 2 --cores 2 \
      --net0 virtio,bridge=vmbr0,firewall=1,macaddr=${mac} \
      --args '-virtfs local,path=/eggs/shared,mount_tag=eggs_shared,security_model=none,id=eggs_shared'"

    # 3. INIEZIONE DINAMICA DELLA CHIAVE (Il pezzo nuovo)
    # Rileva automaticamente se usi una chiave RSA o ED25519 su colibri
    if [ -f "$HOME/.ssh/id_rsa.pub" ]; then
        LOCAL_PUB_KEY=$(cat "$HOME/.ssh/id_rsa.pub")
    elif [ -f "$HOME/.ssh/id_ed25519.pub" ]; then
        LOCAL_PUB_KEY=$(cat "$HOME/.ssh/id_ed25519.pub")
    else
        echo "❌ Errore: Nessuna chiave pubblica (~/.ssh/id_rsa.pub o id_ed25519.pub) trovata su colibri!"
        return
    fi

    # Spedisce la chiave di colibri in un file temporaneo sul Proxmox padre
    ssh "$PVE_TARGET" "echo '$LOCAL_PUB_KEY' > /tmp/colibri_key_${vmid}.pub"

    # Configura Cloud-Init inserendo l'IP locale e forzando l'utente 'artisan' con la tua chiave
    ssh "$PVE_TARGET" "qm set $vmid --ipconfig0 ip=${ip}/24,gw=${PVE_GW:-192.168.1.254}"
    ssh "$PVE_TARGET" "qm set $vmid --nameserver 8.8.8.8"
    ssh "$PVE_TARGET" "qm set $vmid --ciuser artisan"
    ssh "$PVE_TARGET" "qm set $vmid --sshkey /tmp/colibri_key_${vmid}.pub"

    # Pulizia del file temporaneo sul nodo Proxmox padre
    ssh "$PVE_TARGET" "rm /tmp/colibri_key_${vmid}.pub"

    # --- INIEZIONE PACCHETTI (Dinamica per Distro) ---
    LOCAL_YAML_FILE="${SCRIPT_DIR}/packages-${target_name}.yaml"
    
    if [ -f "$LOCAL_YAML_FILE" ]; then
        echo "📦 Trovato file pacchetti per $target_name, iniezione in corso..."
        PVE_SNIPPET_DIR="/var/lib/vz/snippets"
        REMOTE_YAML_FILE="${PVE_SNIPPET_DIR}/user-data-${vmid}.yaml"

        # Copia il file specifico della distro tramite l'IP di PVE_TARGET
        scp "$LOCAL_YAML_FILE" "${PVE_TARGET}:${REMOTE_YAML_FILE}"

        # Istruisce Proxmox ad usarlo indicando lo storage attivo father-local
        ssh "$PVE_TARGET" "qm set $vmid --cicustom 'user=father-local:snippets/user-data-${vmid}.yaml'"
    else
        echo "⏩ Nessun file pacchetti ($LOCAL_YAML_FILE) trovato. Salto l'installazione software."
    fi

    echo "✅ VM $vmid ($name) creata all'indirizzo $ip con MAC $mac!"
    echo "👉 Avvia la VM con: ssh $PVE_TARGET 'qm start $vmid'"
}

# Ciclo di creazione (Massiva o Singola)
if [ "$DISTRO" == "all" ]; then
    DISTROS=("ALPINE" "ARCH" "DEBIAN" "DEVUAN" "FEDORA" "MANJARO" "OPENSUSE" "UBUNTU")
    for d in "${DISTROS[@]}"; do
        var_check="VTMN_${d}"
        if [ -n "${!var_check}" ]; then
            create_vm "$d"
            echo "----------------------------------------"
        fi
    done
else
    create_vm "$DISTRO"
fi
