#!/bin/bash
# Uso standard: p4start debian
# Uso con ISO:  p4start debian naked:iso/la-tua-uovo.iso

CONFIG_FILE="$HOME/forge/bin/p4config"

if [ ! -f "$CONFIG_FILE" ]; then 
    echo "Errore: p4config non trovato in $CONFIG_FILE!"
    exit 1
fi
source "$CONFIG_FILE"

DISTRO=$1
ISO_PATH=$2 # Argomento opzionale per montare una ISO live da testare

if [ -z "$DISTRO" ]; then
    echo "Uso: p4start [debian|arch|manjaro|fedora] [percorso_iso_opzionale]"
    exit 1
fi

# 2. Punta alla nuova stringa compatta
VAR_NAME="VTMN_${DISTRO^^}"
STRING_VALUE=${!VAR_NAME}

if [ -z "$STRING_VALUE" ]; then 
    echo "❌ Errore: Distro '$DISTRO' non configurata in p4config (VTMN_ mancante)!"
    exit 1
fi

# 3. Estrazione dei dati
IFS=',' read -r vmid template_id mac target_ip vm_name <<< "$STRING_VALUE"

# Se è stata passata una ISO, la agganciamo prima del boot
if [ -n "$ISO_PATH" ]; then
    echo "💿 Aggancio la ISO $ISO_PATH al lettore CD della VM $vmid..."
    ssh "$PVE_TARGET" "qm set $vmid --ide2 ${ISO_PATH},media=cdrom"
fi

echo "🚀 Accensione fucina $DISTRO (VMID: $vmid) sul nodo $PVE_NODE..."
ssh "$PVE_TARGET" "qm start $vmid"
