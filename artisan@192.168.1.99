#!/bin/bash

echo "🔍 Ispezione dell'ambiente in corso..."

# 1. Rilevamento automatico del sistema operativo
if [ -f /etc/os-release ]; then
    # Importa le variabili native del sistema (ID, PRETTY_NAME, ecc.)
    source /etc/os-release
else
    echo "❌ Errore: File /etc/os-release non trovato. Impossibile rilevare il sistema."
    exit 1
fi

# 2. Normalizzazione del nome della fucina
# Gestisce casi speciali come "opensuse-tumbleweed" o "opensuse-leap"
if [[ "$ID" == *"opensuse"* ]] || [[ "$ID_LIKE" == *"suse"* ]]; then
    FORGE="opensuse"
else
    FORGE=$ID
fi

echo "🛠️ Sistema rilevato: $PRETTY_NAME"
echo "⚙️ Avvio autoconfigurazione fucina per: $FORGE..."

# 3. Applicazione delle configurazioni specifiche
if [ "$FORGE" == "alpine" ]; then
    echo "Impostazione rete statica Alpine (192.168.1.201)..."
    cat <<EOF | sudo tee /etc/network/interfaces
auto lo
iface lo inet loopback

auto ens18
iface ens18 inet static
    address 192.168.1.201
    netmask 255.255.255.0
    gateway 192.168.1.254
EOF
    echo -e "nameserver 192.168.1.254\nnameserver 8.8.8.8\nnameserver 8.8.4.4" | sudo tee /etc/resolv.conf
    sudo /etc/init.d/networking restart

    echo "Installazione strumenti di sviluppo Alpine..."
    sudo apk update
    sudo apk add alpine-sdk go

elif [ "$FORGE" == "arch" ]; then
    echo "Impostazione rete statica Arch tramite systemd-networkd (192.168.1.202)..."
    sudo rm -f /etc/systemd/network/*.network
    sudo mkdir -p /etc/systemd/network/

    cat <<EOF | sudo tee /etc/systemd/network/20-ens18.network
[Match]
Name=ens18

[Network]
Address=192.168.1.202/24
Gateway=192.168.1.254
DNS=192.168.1.254
DNS=8.8.8.8
EOF

    sudo systemctl enable --now systemd-networkd
    sudo systemctl enable --now systemd-resolved
    sudo ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf
    sudo systemctl restart systemd-networkd

    echo "Installazione strumenti di sviluppo Arch..."
    sudo pacman -Sy --noconfirm base-devel go
    
elif [ "$FORGE" == "debian" ]; then
    echo "Impostazione rete statica Debian (192.168.1.203)..."
    cat <<EOF | sudo tee /etc/network/interfaces
source /etc/network/interfaces.d/*

auto lo
iface lo inet loopback

allow-hotplug ens18
iface ens18 inet static
    address 192.168.1.203
    netmask 255.255.255.0
    gateway 192.168.1.254
    dns-nameservers 192.168.1.254 8.8.8.8 8.8.4.4
EOF
    sudo systemctl restart networking

    echo "Installazione strumenti di sviluppo Debian..."
    sudo apt-get update
    sudo apt-get install -y build-essential golang dpkg-dev

elif [ "$FORGE" == "fedora" ]; then
    echo "Impostazione rete statica Fedora (192.168.1.204)..."
    sudo nmcli con add type ethernet ifname ens18 con-name ens18 \
      ipv4.method manual \
      ipv4.addresses 192.168.1.204/24 \
      ipv4.gateway 192.168.1.254 \
      ipv4.dns "192.168.1.254 8.8.8.8 8.8.4.4"
    sudo nmcli con up "ens18"

    echo "Installazione strumenti di sviluppo Fedora..."
    sudo dnf install -y go @development-tools rpm-build rpmdevtools

elif [ "$FORGE" == "manjaro" ]; then
    echo "Impostazione rete statica Arch tramite systemd-networkd (192.168.1.206)..."
    sudo rm -f /etc/systemd/network/*.network
    sudo mkdir -p /etc/systemd/network/

    cat <<EOF | sudo tee /etc/systemd/network/20-ens18.network
[Match]
Name=ens18

[Network]
Address=192.168.1.205/24
Gateway=192.168.1.254
DNS=192.168.1.254
DNS=8.8.8.8
EOF

    sudo systemctl enable --now systemd-networkd
    sudo systemctl enable --now systemd-resolved
    sudo ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf
    sudo systemctl restart systemd-networkd

    echo "Installazione strumenti di sviluppo Manjaro..."
    sudo pacman -Sy --noconfirm base-devel go

elif [ "$FORGE" == "opensuse" ]; then
    echo "Impostazione rete statica openSUSE (192.168.1.205)..."
    sudo nmcli con add type ethernet ifname ens18 con-name ens18 \
      ipv4.method manual \
      ipv4.addresses 192.168.1.205/24 \
      ipv4.gateway 192.168.1.254 \
      ipv4.dns "192.168.1.254 8.8.8.8 8.8.4.4"
    sudo nmcli con up "ens18"

    echo "Installazione strumenti di sviluppo openSUSE..."
    sudo zypper install -y go rpm-build rpmdevtools -t pattern devel_basis

else
    echo "❌ Errore: Fucina '$FORGE' non supportata da questo script."
    exit 1
fi

echo "✅ Autoconfigurazione completata con successo! La fucina è pronta."
